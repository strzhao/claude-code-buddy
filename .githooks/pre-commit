#!/bin/bash
# pre-commit hook: build + test before every commit

echo "🔨 Building..."
swift build 2>&1
if [ $? -ne 0 ]; then
    echo "❌ Build failed. Commit aborted."
    exit 1
fi

echo "🧪 Testing..."
swift test 2>&1
if [ $? -ne 0 ]; then
    echo "❌ Tests failed. Commit aborted."
    exit 1
fi

echo "✅ All checks passed."
